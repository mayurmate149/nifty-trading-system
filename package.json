  "private": true,
  "description": "Rule-based options trading assistant for Nifty/BankNifty via 5paisa Xstream API",
  "scripts": {
    "dev": "next dev",
    "dev:sim": "cd simulator && node server.js",
    "dev:ws-gateway": "cd xstream-ws-gateway && npm run dev",
